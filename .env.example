# ─── Application ─────────────────────────────────────────
NODE_ENV=development

# ─── Backend ─────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fleetpilot?schema=public"

# ─── JWT Authentication ────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production_use_64_byte_random_hex
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_me_refresh_use_different_64_byte_random_hex
JWT_REFRESH_EXPIRES_IN=7d

# ─── File Uploads ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Driver Rest-Time Threshold (configurable) ────────────
DRIVER_REST_THRESHOLD_HOURS=2

# ─── Email (optional — set to enable email reminders) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fleetpilot.dev

# ─── Redis (optional — for BullMQ job queues) ─────────────
REDIS_URL=redis://localhost:6379
